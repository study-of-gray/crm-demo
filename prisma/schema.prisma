generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  companyUsers     CompanyUser[]
  companyCustomers CompanyCustomer[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  companyUsers      CompanyUser[]
  assignedCustomers CustomerAssignment[]

  sentMessages      Message[]     @relation("UserSentMessages")
  uploadedDocuments Document[]    @relation("UploadedDocuments")
  assignedTickets   Ticket[]      @relation("AssignedTickets")
  ticketReplies     TicketReply[] @relation("UserTicketReplies")
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  password    String
  description String?
  createdAt   DateTime @default(now())

  companyCustomers CompanyCustomer[]
  assignedStaff    CustomerAssignment[]

  receivedMessages Message[]     @relation("CustomerReceivedMessages")
  documents        Document[]    @relation("CustomerDocuments")
  tickets          Ticket[]      @relation("CustomerTickets")
  ticketReplies    TicketReply[] @relation("CustomerTicketReplies")
}

model Message {
  id        String   @id @default(cuid())
  subject   String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  senderId String
  sender   User   @relation("UserSentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  receiverId String
  receiver   Customer @relation("CustomerReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId])
  @@index([senderId])
  @@index([isRead])
}

model Document {
  id          String   @id @default(cuid())
  name        String
  fileName    String
  filePath    String
  fileSize    Int
  mimeType    String
  description String?
  uploadedAt  DateTime @default(now())
  updatedAt   DateTime @updatedAt

  customerId String
  customer   Customer @relation("CustomerDocuments", fields: [customerId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation("UploadedDocuments", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([uploadedById])
}

model CompanyUser {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model CompanyCustomer {
  id         String   @id @default(cuid())
  companyId  String
  customerId String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([companyId, customerId])
  @@index([companyId])
  @@index([customerId])
}

model CustomerAssignment {
  id         String   @id @default(cuid())
  userId     String
  customerId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, customerId])
  @@index([userId])
  @@index([customerId])
}

model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // 提交工单的客户
  customerId String
  customer   Customer @relation("CustomerTickets", fields: [customerId], references: [id], onDelete: Cascade)

  // 处理工单的员工
  assignedToId String?
  assignedTo   User?   @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)

  // 工单回复
  replies TicketReply[]

  @@index([customerId])
  @@index([assignedToId])
  @@index([status])
  @@index([priority])
}

model TicketReply {
  id         String   @id @default(cuid())
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  // 回复作者可以是员工或客户
  authorUserId String?
  authorUser   User?   @relation("UserTicketReplies", fields: [authorUserId], references: [id], onDelete: Cascade)

  authorCustomerId String?
  authorCustomer   Customer? @relation("CustomerTicketReplies", fields: [authorCustomerId], references: [id], onDelete: Cascade)

  // 所属工单
  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorUserId])
  @@index([authorCustomerId])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}
