generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())

  companyUsers     CompanyUser[]
  companyCustomers CompanyCustomer[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now())

  companyUsers      CompanyUser[]
  assignedCustomers CustomerAssignment[]

  sentMessages Message[] @relation("UserSentMessages")
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  phone       String?
  password    String
  description String?
  createdAt   DateTime @default(now())

  companyCustomers CompanyCustomer[]
  assignedStaff    CustomerAssignment[]

  receivedMessages Message[] @relation("CustomerReceivedMessages")
}

model Message {
  id        String   @id @default(cuid())
  subject   String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ 发送者（只能是员工）
  senderId String
  sender   User   @relation("UserSentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  // ✅ 接收者（只能是客户）
  receiverId String
  receiver   Customer @relation("CustomerReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([receiverId])
  @@index([senderId])
  @@index([isRead])
}

model CompanyUser {
  id        String   @id @default(cuid())
  companyId String
  userId    String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model CompanyCustomer {
  id         String   @id @default(cuid())
  companyId  String
  customerId String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([companyId, customerId])
  @@index([companyId])
  @@index([customerId])
}

model CustomerAssignment {
  id         String   @id @default(cuid())
  userId     String
  customerId String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([userId, customerId])
  @@index([userId])
  @@index([customerId])
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}
